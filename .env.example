# Backend database URL
# SQLite (local development -- no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./pricewatch.db
# PostgreSQL (production / Render):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/amazon_notifier

# Amazon base URL
AMAZON_BASE_URL=https://www.amazon.in

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=["http://localhost:5173"]

# Email notifications (SMTP)
# For Gmail: enable "App Passwords" at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Scheduled price check interval (in minutes, default: 360 = 6 hours)
PRICE_CHECK_INTERVAL_MINUTES=360

# Frontend: set this on the Render static site
# VITE_API_URL=https://your-backend.onrender.com
